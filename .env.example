# Copier ce fichier en « .env.local » (jamais commité) et remplir avec les valeurs de TON projet Supabase.
# Projet Supabase à créer en région Europe (Frankfurt / eu-central-1).

# URL du projet Supabase (Settings → API → Project URL)
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# Clé SECRÈTE service_role (Settings → API → service_role).
# ⚠️ Serveur uniquement, ne JAMAIS l'exposer au navigateur ni la commiter.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...remplace-moi..."

# Tant que ces deux variables sont vides, le site tourne en mode « mock » :
# signer fonctionne en local (en mémoire) sans aucune clé.
#
# Note : ne crée PAS de fichier .dev.vars en parallèle — s'il existe, il a priorité
# et tes valeurs de .env.local seraient ignorées.
