---
// Polices auto-hébergées (RGPD : pas d'appel au CDN Google) via @fontsource
// Corps de texte : PT Sans (police de la charte BCA 2024)
import "@fontsource/pt-sans/400.css";
import "@fontsource/pt-sans/700.css";
import "@fontsource/pt-sans/400-italic.css";
import "@fontsource/pt-sans/700-italic.css";
// Titres : Antonio (alternative libre à « Chantal » de la charte)
import "@fontsource/antonio/400.css";
import "@fontsource/antonio/600.css";
import "@fontsource/antonio/700.css";
// Accents éditoriaux et manuscrits (conservés)
import "@fontsource/fraunces/400.css";
import "@fontsource/fraunces/500.css";
import "@fontsource/fraunces/400-italic.css";
import "@fontsource/fraunces/500-italic.css";
import "@fontsource/caveat-brush/400.css";
import "../styles/global.css";

import { site, nav, footer } from "../data/contenu.ts";

interface Props {
  titre?: string;
  description?: string;
  navActive?: string; // href de l'onglet actif, ex. "/appel"
}
const { titre = site.titreOnglet, description = site.description, navActive = "" } = Astro.props;
const ogImage = new URL("/images/affiche-pesticides.jpg", Astro.site);
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titre}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/jpeg" href="/images/logo-bca.jpg" />
    <!-- Partage social (presse, réseaux) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={titre} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>

  <body>
    <!-- Header (logo + nav) -->
    <header class="site">
      <div class="wrap row">
        <a class="logo" href="/" aria-label="Bio Consom'acteurs — accueil">
          <img src="/images/logo-bca.jpg" alt="Bio Consom'acteurs" />
        </a>
        <nav class="main">
          {nav.map((item) => (
            <a href={item.href} class={item.href === navActive ? "active" : undefined}>{item.label}</a>
          ))}
        </nav>
        <a href="/#signer" class="btn btn-primary">Signer la pétition →</a>
      </div>
    </header>

    <slot />

    <!-- FOOTER -->
    <footer class="site">
      <div class="wrap">
        <div class="cols">
          <div class="col brand-block">
            <div class="display">Pas de pesticides<br /><span class="y">pour nos enfants !</span></div>
            <p>Pétition citoyenne portée par <strong>{site.org}</strong>. {site.adresse}.</p>
          </div>
          {footer.colonnes.map((col) => (
            <div class="col">
              <h4>{col.titre}</h4>
              {col.liens.map((l) =>
                "externe" in l && l.externe ? (
                  <a href={l.href} target="_blank" rel="noopener">{l.label}</a>
                ) : (
                  <a href={l.href}>{l.label}</a>
                )
              )}
            </div>
          ))}
        </div>
        <div class="bottom">
          <div>© {site.annee} {site.org} · {site.domaine}</div>
          <div>
            {footer.legal.map((l) => <a href={l.href}>{l.label}</a>)}
          </div>
        </div>
      </div>
    </footer>

    <!-- Sticky mobile CTA -->
    <div class="sticky-cta">
      <a href="/#signer" class="btn btn-primary">✍️ Signer la pétition</a>
    </div>
  </body>
</html>
