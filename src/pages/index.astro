---
import Base from "../layouts/Base.astro";
import {
  compteur, pourcentObjectif, objectifDynamique, fmt,
  urgence, manifeste, demandes, actions, signature, apropos,
} from "../data/contenu.ts";
// Note : la section « Premier·ères signataires » (personnalités + organisations)
// est retirée pour l'instant — à réafficher plus tard (données conservées dans contenu.ts).

// Illustrations décoratives des 3 cartes « Agir » (SVG inline)
const illustrations = [
  `<svg viewBox="0 0 200 120" fill="none" aria-hidden="true"><path d="M40 38 100 22l60 16-60 18-60-18Z" fill="#EB734D"/><path d="M40 38v42l60 18V56L40 38Z" fill="#CC5733"/><path d="M160 38v42l-60 18V56l60-18Z" fill="#FFCC45"/><path d="M70 30l60 16M70 30v42M130 30l-30 8" stroke="#004D40" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  `<svg viewBox="0 0 200 120" fill="none" aria-hidden="true"><rect x="20" y="30" width="160" height="76" rx="8" fill="#CEDCAE"/><path d="M20 78c20-8 38 4 60-4s44-12 70-2v34H20V78Z" fill="#B0C27D"/><circle cx="70" cy="62" r="10" fill="#fff" stroke="#004D40" stroke-width="2"/><path d="M70 52v-8M70 52a10 10 0 0 0 0 20" stroke="#EB734D" stroke-width="3" stroke-linecap="round"/><circle cx="70" cy="62" r="3" fill="#004D40"/><circle cx="130" cy="50" r="6" fill="#FFCC45" stroke="#004D40" stroke-width="2"/><circle cx="155" cy="80" r="5" fill="#fff" stroke="#004D40" stroke-width="2"/></svg>`,
  `<svg viewBox="0 0 200 120" fill="none" aria-hidden="true"><rect x="30" y="68" width="140" height="6" rx="2" fill="#004D40"/><rect x="40" y="74" width="6" height="22" rx="1" fill="#004D40"/><rect x="154" y="74" width="6" height="22" rx="1" fill="#004D40"/><circle cx="70" cy="50" r="10" fill="#EB734D"/><path d="M55 70c0-8 7-12 15-12s15 4 15 12" fill="#EB734D"/><circle cx="130" cy="50" r="10" fill="#FFCC45" stroke="#004D40" stroke-width="2"/><path d="M115 70c0-8 7-12 15-12s15 4 15 12" fill="#FFCC45" stroke="#004D40" stroke-width="2"/><path d="M85 32h30c3 0 6 2 6 6v8c0 3-3 6-6 6h-22l-8 6 1-6h-1c-3 0-6-3-6-6v-8c0-4 3-6 6-6Z" fill="#fff" stroke="#004D40" stroke-width="2"/><circle cx="95" cy="42" r="2" fill="#004D40"/><circle cx="103" cy="42" r="2" fill="#004D40"/><circle cx="111" cy="42" r="2" fill="#004D40"/></svg>`,
];
---

<Base>
  <!-- Bandeau de chiffres -->
  <div class="ticker">
    <div class="wrap">
      <div class="row">
        <span class="item"><span class="num" data-cpt="signataires">{fmt(compteur.signataires)}</span><span class="lbl">signataires</span></span>
        <span class="item"><span class="num">{compteur.distributions}</span><span class="lbl">distributions enregistrées</span></span>
        <span class="item"><span class="num" data-cpt="communes">{compteur.communes}</span><span class="lbl">communes mobilisées</span></span>
        <span class="item goal"><span class="lbl">Objectif</span><span class="num" data-cpt="objectif">{fmt(objectifDynamique(compteur.signataires))}</span><span class="lbl">signatures</span></span>
      </div>
    </div>
  </div>

  <!-- HERO (épuré : boutons + compteur posés sur l'affiche) -->
  <section class="hero">
    <div class="wrap">
      <div class="stage">
        <div class="poster">
          <img src="/images/affiche-pesticides.jpg" alt="Pas de pesticides pour nos enfants — une petite signature pour vous, un grand pas pour leur santé. Affiche officielle de la campagne." />
        </div>
        <div class="overlay">
          <div class="ctas">
            <a href="#signer" class="btn btn-primary">✍️ Je signe la pétition</a>
            <a href="/appel" class="btn btn-appel">Lire l'appel</a>
          </div>
          <div class="meter">
            <p class="count">
              <span class="num" id="counter">{fmt(compteur.signataires)}</span>
              <span class="cl"><strong>signataires</strong> à ce jour</span>
            </p>
            <div class="prog">
              <span class="bar"><i id="counter-bar" style={`width:${pourcentObjectif(compteur.signataires)}%`}></i></span>
              <span class="goal" id="counter-goal">{pourcentObjectif(compteur.signataires)} % de l'objectif des {fmt(objectifDynamique(compteur.signataires))}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SIGNER (remonté juste sous le hero) -->
  <section class="sign" id="signer">
    <div class="wrap">
      <div class="grid">
        <div class="left">
          <span class="eyebrow" style="color:var(--yellow)"><span style="background:var(--yellow)"></span>{signature.eyebrow}</span>
          <h2 set:html={signature.titreHtml}></h2>
          <div class="hand" set:html={signature.slogan}></div>
          <div class="meta">
            <div class="row">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-6 8-13a8 8 0 0 0-16 0c0 7 8 13 8 13Z"/><circle cx="12" cy="9" r="3"/></svg>
              <span>{signature.garanties[0]}</span>
            </div>
            <div class="row">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span>{signature.garanties[1]}</span>
            </div>
            <div class="row">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>{signature.garanties[2]}</span>
            </div>
          </div>
        </div>
        <div class="right">
          <form class="form-card" id="form-signature" method="POST" action="/api/signer">
            <!-- Anti-robot : champ piège (honeypot), invisible pour les humains -->
            <input type="text" name="site_web" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0" />
            <div class="row">
              <div>
                <label class="label" for="fn">Prénom</label>
                <input class="field" id="fn" name="prenom" type="text" placeholder="Camille" required autocomplete="given-name" />
              </div>
              <div>
                <label class="label" for="ln">Nom</label>
                <input class="field" id="ln" name="nom" type="text" placeholder="Dupont" required autocomplete="family-name" />
              </div>
            </div>
            <div class="row single">
              <div>
                <label class="label" for="em">Email</label>
                <input class="field" id="em" name="email" type="email" placeholder="camille@exemple.fr" required autocomplete="email" />
              </div>
            </div>
            <div class="row">
              <div>
                <label class="label" for="cp">Code postal</label>
                <input class="field" id="cp" name="code_postal" type="text" inputmode="numeric" maxlength="5" placeholder="75011" required autocomplete="postal-code" />
              </div>
              <div>
                <label class="label" for="ph">Téléphone <span style="color:var(--muted);text-transform:none;letter-spacing:0">— facultatif</span></label>
                <input class="field" id="ph" name="telephone" type="tel" placeholder="06 12 34 56 78" autocomplete="tel" />
              </div>
            </div>
            <label class="check">
              <input type="checkbox" name="info_campagne" checked />
              <span>Je soutiens la campagne « Pas de pesticides pour nos enfants&nbsp;» et accepte de recevoir des informations sur son avancée. <em style="font-style:normal;color:var(--muted)">(Intérêt légitime, désinscription à tout moment.)</em></span>
            </label>
            <label class="check">
              <input type="checkbox" name="newsletter" />
              <span>Je souhaite recevoir la <strong>lettre d'information</strong> de Bio Consom'acteurs (actualités, mobilisations, agenda). <em style="font-style:normal;color:var(--muted)">(Consentement explicite.)</em></span>
            </label>
            <button type="submit" class="btn btn-primary submit">✍️ Je signe la pétition</button>
            <p class="rgpd" id="form-message" aria-live="polite">Vos données sont collectées par Bio Consom'acteurs (responsable de traitement). Elles sont hébergées en Europe par Supabase (Frankfurt) et ne sont jamais cédées à des tiers. Vous disposez de droits d'accès, de rectification, d'opposition et d'effacement, détaillés dans notre <a href="/confidentialite" style="color:var(--muted);text-decoration:underline">politique de confidentialité</a> (contact : <a href="mailto:contact@bioconsomacteurs.org" style="color:var(--muted);text-decoration:underline">contact@bioconsomacteurs.org</a>).</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- POURQUOI MAINTENANT -->
  <section class="urgency" id="manifeste">
    <div class="wrap">
      <div class="lead-row">
        <div>
          <span class="eyebrow">{urgence.eyebrow}</span>
          <h2 set:html={urgence.titreHtml}></h2>
        </div>
        <div class="body">
          {urgence.corpsHtml.map((p) => <p set:html={p}></p>)}
          <div class="pull">{urgence.pull}</div>
        </div>
      </div>
      <div class="stats">
        {urgence.stats.map((s) => (
          <div class={s.alt ? "stat alt" : "stat"}>
            <span class="corner">{s.n}</span>
            <div class="big">{s.big}<span class="u">{s.u}</span></div>
            {s.only && <div class="only">{s.only}</div>}
            <div class="ttl">{s.ttl}</div>
            <div class="src">{s.src}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NOS DEMANDES -->
  <section class="demands" id="demandes">
    <div class="wrap">
      <div class="head">
        <div>
          <span class="eyebrow">{demandes.eyebrow}</span>
          <h2 set:html={demandes.titreHtml}></h2>
        </div>
        <p class="intro">{demandes.intro}</p>
      </div>
      <div class="demand-grid">
        {demandes.liste.map((d) => (
          <article class={d.variante ? `demand ${d.variante}` : "demand"}>
            <div class="n">{d.n}</div>
            <div class="verb">{d.verbe}</div>
            <p>{d.texte}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- COMMENT AGIR -->
  <section class="act" id="agir">
    <div class="wrap">
      <div class="head">
        <span class="eyebrow">{actions.eyebrow}</span>
        <h2 set:html={actions.titreHtml}></h2>
        <p class="sub">{actions.sous}</p>
      </div>
      <div class="actions">
        {actions.cartes.map((c, i) => (
          <article class={c.featured ? "action featured" : "action"}>
            <div class="top">
              <div class="step">{c.step}</div>
              <h3>{c.titre}</h3>
              <p set:html={c.texteHtml}></p>
              <ul>
                {c.points.map((pt) => <li set:html={pt}></li>)}
              </ul>
            </div>
            <div class="ill" style={c.illStyle || undefined} set:html={illustrations[i]}></div>
            <div class="foot">
              <span class="small">{c.footSmall}</span>
              <a href={c.cta.href} class={`btn ${c.cta.classe}`}>{c.cta.label}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- QUI SOMMES-NOUS -->
  <section class="about" id="bca">
    <div class="wrap">
      <div class="grid">
        <div>
          <span class="eyebrow">{apropos.eyebrow}</span>
          <h2>{apropos.titre}</h2>
          {apropos.parasHtml.map((p) => <p set:html={p}></p>)}
          <a href="https://bioconsomacteurs.org" target="_blank" rel="noopener" class="btn btn-dark" style="margin-top:24px">Découvrir Bio Consom'acteurs ↗</a>
        </div>
        <div class="stats-mini">
          {apropos.mini.map((m) => (
            <div class="mini">
              {"bigHtml" in m ? <div class="big" set:html={m.bigHtml}></div> : <div class="big">{m.big}</div>}
              <div class="lbl">{m.lbl}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    // Compteur en direct + envoi du formulaire de signature (amélioration progressive).
    const fmtFr = (n) => Number(n).toLocaleString('fr-FR');

    async function rafraichirCompteur() {
      try {
        const r = await fetch('/api/compteur', { headers: { accept: 'application/json' } });
        if (!r.ok) return;
        const d = await r.json();
        if (typeof d.signataires === 'number') {
          document.querySelectorAll('[data-cpt="signataires"]').forEach((el) => (el.textContent = fmtFr(d.signataires)));
          const big = document.getElementById('counter');
          if (big) big.textContent = fmtFr(d.signataires);
          const obj = d.objectif || 20000;
          document.querySelectorAll('[data-cpt="objectif"]').forEach((el) => (el.textContent = fmtFr(obj)));
          const pct = obj > 0 ? Math.min(100, Math.round((d.signataires / obj) * 100)) : 0;
          const bar = document.getElementById('counter-bar');
          if (bar) bar.style.width = pct + '%';
          const goal = document.getElementById('counter-goal');
          if (goal) goal.textContent = pct + " % de l'objectif des " + fmtFr(obj);
        }
        if (typeof d.communes === 'number') {
          document.querySelectorAll('[data-cpt="communes"]').forEach((el) => (el.textContent = fmtFr(d.communes)));
        }
      } catch (_) {}
    }
    rafraichirCompteur();

    const form = document.getElementById('form-signature');
    if (form) {
      const btn = form.querySelector('button[type="submit"]');
      const msg = document.getElementById('form-message');
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (btn.disabled) return;
        const texteOrigine = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'Envoi…';
        try {
          const res = await fetch('/api/signer', { method: 'POST', body: new FormData(form) });
          const data = await res.json().catch(() => ({}));
          if (res.ok && data.ok) {
            btn.textContent = data.deja ? '✓ Vous aviez déjà signé — merci !' : '✓ Merci, votre signature est enregistrée';
            btn.style.background = 'var(--green-700)';
            btn.style.boxShadow = '0 4px 0 var(--green-900)';
            btn.style.color = 'var(--cream)';
            form.querySelectorAll('input').forEach((i) => (i.disabled = true));
            rafraichirCompteur();
          } else {
            btn.disabled = false;
            btn.textContent = texteOrigine;
            if (msg) msg.textContent = data.erreur || 'Une erreur est survenue. Merci de réessayer.';
          }
        } catch (_) {
          btn.disabled = false;
          btn.textContent = texteOrigine;
          if (msg) msg.textContent = 'Connexion impossible. Merci de réessayer.';
        }
      });
    }
  </script>
</Base>
